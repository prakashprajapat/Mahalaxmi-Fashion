# Copy this file to .env.local and fill in your values

# Backend API URL (.NET Web API)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# (Optional) Next.js runs on port 3000 by default
# PORT=3000

# ── AI Chatbot (Laxmi) ────────────────────────────────────────────────
# Get a key from https://platform.openai.com/api-keys  (paid, pay-as-you-go)
# Keep it SERVER-SIDE only — never prefix with NEXT_PUBLIC.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: default is gpt-4o-mini (cheapest good model)
# OPENAI_MODEL=gpt-4o-mini
